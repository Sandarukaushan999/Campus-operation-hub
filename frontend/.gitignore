# =========================================================
# Frontend (React + Vite) .gitignore
# =========================================================

# ---------- Dependencies ----------
node_modules/
.pnp/
.pnp.js
.yarn/
.pnpm-store/

# ---------- Build output ----------
dist/
dist-ssr/
build/
.vite/
*.local

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Test coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- Environment files ----------
.env
.env.*
!.env.example

# ---------- Editor / IDE ----------
.vscode/
.idea/
*.iml
*.swp
*.swo

# ---------- Claude Code workspace ----------
.claude/

# ---------- OS junk ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- Misc ----------
*.tsbuildinfo
.eslintcache
.cache/
tmp/
