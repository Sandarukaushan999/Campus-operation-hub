# =========================================================
# Smart Campus Hub - environment template
#
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
#
# The real ".env" file is in .gitignore and is NEVER committed.
# =========================================================

# ----- MongoDB connection -----
# Use either the team's shared Atlas cluster (ask the team lead for the password)
# or your own local MongoDB. Examples:
#
#   Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartcampusdb?retryWrites=true&w=majority
#   Local:  mongodb://localhost:27017/smartcampusdb
#
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartcampusdb?retryWrites=true&w=majority

# ----- JWT signing secret -----
# Must be at least 32 characters. Generate one with:
#     openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min

# ----- JWT lifetime (seconds) -----
# 86400 = 24 hours
JWT_EXPIRATION_SECONDS=86400

# ----- Frontend API base URL -----
# Where the browser should send API requests. This is NOT the docker-compose
# service name ("backend") because the browser runs on the host, not inside
# the container. Override this when deploying to a real domain.
VITE_API_BASE_URL=http://localhost:8080/api

# ----- CORS allowed origins (comma-separated) -----
# Browsers that are allowed to call the backend API. Defaults below cover the
# Vite dev server. Add your production domain(s) here for deploys.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Optional: seed temporary demo accounts -----
# Enable this ONLY for local dev. The backend will create these accounts
# if the emails do not already exist.

APP_SEED_ENABLED=true
APP_SEED_ADMIN_EMAIL=admin@campus.local
APP_SEED_ADMIN_PASSWORD=change-me
APP_SEED_TECHNICIAN_EMAIL=tech@campus.local
APP_SEED_TECHNICIAN_PASSWORD=change-me
APP_SEED_USER_EMAIL=user@campus.local
APP_SEED_USER_PASSWORD=change-me

