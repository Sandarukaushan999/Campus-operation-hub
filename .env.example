# =========================================================
# Smart Campus Hub - Local Development Environment
# Generated from .env.example
# =========================================================

# ----- MongoDB connection -----
# Using local MongoDB by default. Change to Atlas URI if needed:
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartcampusdb?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/smartcampusdb
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/smartcampusdb

# ----- JWT signing secret -----
# Must be at least 32 characters
JWT_SECRET=smart-campus-hub-local-dev-secret-key-2024
APP_SECURITY_JWT_SECRET=smart-campus-hub-local-dev-secret-key-2024

# ----- JWT lifetime (seconds) -----
# 86400 = 24 hours
JWT_EXPIRATION_SECONDS=86400
APP_SECURITY_JWT_EXPIRATION_SECONDS=86400

# ----- Frontend API base URL -----
VITE_API_BASE_URL=http://localhost:8080/api

# ----- CORS allowed origins (comma-separated) -----
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Google OAuth2 (backend-driven login) -----
# These must match the OAuth client you created in Google Cloud Console.
# Authorized redirect URI to add in Google Cloud Console:
#   http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# After backend login, it redirects the browser back to the frontend with `?token=...`
# This URL must match your frontend dev server origin/port.
OAUTH2_REDIRECT_URI=http://localhost:5173/oauth2/callback

# ----- Seed demo accounts (local dev only) -----
APP_SEED_ENABLED=true
APP_SEED_ADMIN_EMAIL=admin@campus.local
APP_SEED_ADMIN_PASSWORD=Admin@1234
APP_SEED_TECHNICIAN_EMAIL=tech@campus.local
APP_SEED_TECHNICIAN_PASSWORD=Tech@1234
APP_SEED_USER_EMAIL=user@campus.local
APP_SEED_USER_PASSWORD=User@1234
