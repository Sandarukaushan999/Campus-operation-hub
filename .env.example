# =========================================================
# Smart Campus Hub - environment template
#
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
#
# The real ".env" file is in .gitignore and is NEVER committed.
# =========================================================

# ----- MongoDB connection -----
# Use either the team's shared Atlas cluster (ask the team lead for the password)
# or your own local MongoDB. Examples:
#
#   Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartcampusdb?retryWrites=true&w=majority
#   Local:  mongodb://localhost:27017/smartcampusdb
#
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/smartcampusdb?retryWrites=true&w=majority

# ----- JWT signing secret -----
# Must be at least 32 characters. Generate one with:
#     openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min

# ----- JWT lifetime (seconds) -----
# 86400 = 24 hours
JWT_EXPIRATION_SECONDS=86400

# ----- Frontend API base URL -----
# Where the browser should send API requests. This is NOT the docker-compose
# service name ("backend") because the browser runs on the host, not inside
# the container. Override this when deploying to a real domain.
VITE_API_BASE_URL=http://localhost:8080/api

